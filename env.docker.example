# Copy to `.env` in this directory (repo root) so Docker Compose can substitute variables.
# Compose loads `.env` automatically for interpolation in docker-compose.yml — it is not the same as librequant/.env.local.
#
# LibreQuant Jupyter workspace: host folder mounted at /home/jovyan/work/librequant in the container.
# Everything the UI saves (notebooks, data/uploads, config/credentials.env) lives under this folder on your machine.
#
# Examples (macOS):
#   LIBREQUANT_JUPYTER_WORKSPACE_HOST=/Users/yourname/Desktop/notebooks
#   LIBREQUANT_JUPYTER_WORKSPACE_HOST=/Users/yourname/Documents/LibreQuantWorkspace
#
# Relative paths are resolved from the directory that contains docker-compose.yml (repo root).
# Default if unset: ./jupyter-workspace (created automatically; gitignored)
#
# LIBREQUANT_JUPYTER_WORKSPACE_HOST=./jupyter-workspace

# --- PostgreSQL (docker-compose `postgres` service) ---
# Optional overrides (defaults: user librequant, password librequant — local dev only; see SECURITY.md).
# The bootstrap user is a PostgreSQL superuser. If you set POSTGRES_PASSWORD, avoid URL-reserved
# characters (@ : / ? # %) so LIBREQUANT_DATABASE_URL in Jupyter interpolates cleanly.
#
# POSTGRES_USER=librequant
# POSTGRES_PASSWORD=librequant
#
# Published port on your machine (container still listens on 5432 inside Docker). If you see
# "address already in use" on 5432, pick another port, e.g.:
# POSTGRES_HOST_PORT=5433
#
# Host SQL clients: 127.0.0.1 and the published port (default 5432), database librequant, same user/password unless overridden.
# Not bound to the LAN by default (see SECURITY.md).
#
# MLflow UI/API: 127.0.0.1:5000 (docker-compose `mlflow` service). For the Next.js app on the host,
# set MLFLOW_TRACKING_URI=http://127.0.0.1:5000 in librequant/.env.local (see librequant/.env.example).
# The bundled MLflow 2.x server does not use Host-header allowlists (MLflow 3+ adds that). If you
# upgrade the server image to v3+, you may need to set `MLFLOW_SERVER_ALLOWED_HOSTS` (merge defaults
# with `mlflow` / `mlflow:5000`) so Jupyter→MLflow is not rejected with 403.
#
# Jupyter (compose): `MLFLOW_BACKEND_STORE_URI` matches the MLflow server Postgres DB so notebooks can
# permanently drop a soft-deleted experiment that still blocks a name with a bad `file:` artifact root.
# Compose uses `postgresql+psycopg://...` (psycopg3) so SQLAlchemy does not require `psycopg2`.
# The `mlflow` service image tag must match the `mlflow` package version in packages/librequant
# (both pinned to the same release, e.g. v2.22.4).
#
# Downgrading MLflow (e.g. from `ghcr.io/mlflow/mlflow:latest` v3 to pinned v2): the `postgres_data`
# volume may still contain MLflow 3.x migrations (e.g. Alembic error "Can't locate revision
# 'c3d6457b6d8a'"). Reset only the tracking DB (keeps `librequant` data):
#   docker compose stop mlflow jupyter
#   docker compose exec postgres psql -U librequant -d postgres -c 'DROP DATABASE IF EXISTS mlflow WITH (FORCE);'
#   docker compose exec postgres psql -U librequant -d postgres -c 'CREATE DATABASE mlflow;'
#   docker compose up -d
# Or wipe all Postgres data: `docker compose down -v` (also deletes the `librequant` database).
#
# The `mlflow-db-init` service creates the `mlflow` database if it is missing (e.g. you reused an old
# `postgres_data` volume from before MLflow was added). Fresh installs still use init SQL under docker/postgres/.
