# Next.js app — build & deps (paths relative to this directory)
# OS, editors, Cursor, and repo-wide rules: see ../.gitignore

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

