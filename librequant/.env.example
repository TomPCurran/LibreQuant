# LibreQuant local environment template — copy to `.env.local` (see librequant/README.md, Configuration).
#
# IMPORTANT: NEXT_PUBLIC_* variables are baked into the client bundle at BUILD time (`next build`).
# Set them before `npm run build`, not only before `npm run start`. `prebuild` creates `.env.local`
# from this file when missing so a typical local build picks up defaults.
#
# Public (exposed to browser) — use only for local dev
# Use 127.0.0.1 so the browser hits IPv4 loopback: Docker maps 127.0.0.1:8888 only; "localhost"
# often resolves to ::1 on macOS and fails with ECONNREFUSED. (App also normalizes localhost→127.0.0.1.)
NEXT_PUBLIC_JUPYTER_BASE_URL=http://127.0.0.1:8888
# Sensitive: equivalent to Jupyter login; do not commit real secrets to public repos
NEXT_PUBLIC_JUPYTER_TOKEN=devtoken

# Optional: prefix for browser console messages (default LibreQuant). Set to your fork name for OSS builds.
# NEXT_PUBLIC_CLIENT_LOG_PREFIX=MyProject

# Directory (Jupyter contents path) for the notebook library — relative to server root, no leading slash
NEXT_PUBLIC_JUPYTER_NOTEBOOK_ROOT=work/librequant

# Strategies: default assumes Docker PYTHONPATH (see docker-compose). Set to 0 only to force browser-side sys.path injection (e.g. external Jupyter without PYTHONPATH).
# If you change NOTEBOOK_ROOT or USER_HOME, update PYTHONPATH in docker-compose.yml to match lib/env.ts.
NEXT_PUBLIC_STRATEGIES_VIA_PYTHONPATH=1

# Absolute path to Jupyter Linux user home inside the container (default /home/jovyan). Must be a safe POSIX path.
# NEXT_PUBLIC_JUPYTER_USER_HOME=/home/jovyan

# MLflow Tracking API (server-side `fetch` from Next.js route handlers only). Use loopback — the
# Next.js process runs on the host while MLflow is published at 127.0.0.1:5000 from Docker Compose.
# Jupyter inside Compose uses http://mlflow:5000 via MLFLOW_TRACKING_URI in docker-compose.yml.
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
#
# Optional: when set, `/api/mlflow/*` returns 403 if `X-Forwarded-For` / `X-Real-IP` implies a
# non-loopback client (best-effort; see SECURITY.md).
# MLFLOW_PROXY_REQUIRE_LOOPBACK=1
#
# MLflow UI origin for the sidebar iframe, “Open MLflow UI”, and CSP `frame-src` (see next.config.ts).
# Must be the same host:port you publish for MLflow in the repository root docker-compose.yml (default
# 127.0.0.1:5000). If this URL and Compose disagree, the iframe stays blank or the browser blocks the
# frame with CSP.
# NEXT_PUBLIC_MLFLOW_UI_URL=http://127.0.0.1:5000

# Docker Compose (must match NEXT_PUBLIC_JUPYTER_TOKEN when using compose defaults)
JUPYTER_TOKEN=devtoken
#
# Where Jupyter stores notebooks on your machine: set LIBREQUANT_JUPYTER_WORKSPACE_HOST in a repo-root `.env`
# (see ../env.docker.example). Not read from this file — Compose interpolation uses the repo root `.env` only.

# --- Server-only / Jupyter (never NEXT_PUBLIC_*): market data API keys ---
# Copy real values into `.env.local` only; never commit `.env.local`.
# Docker Compose loads this file into the Jupyter container (see repo root docker-compose.yml)
# so notebook kernels can use the same keys as the Next.js server.
# Optional Alpaca Market Data (https://alpaca.markets/)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# Optional: Alpaca data feed (default iex; use sip if your subscription includes it)
# ALPACA_DATA_FEED=iex
# Optional Polygon / Tiingo (connectors planned; keys reserved for future use)
# POLYGON_API_KEY=
# TIINGO_API_KEY=

# Custom API keys (uppercase A–Z / 0–9 / underscore; set via Data sources UI or add manually)
# MY_VENDOR_API_KEY=

# Set to 1 to show full Jupyter/Yjs console output in dev (default filters known benign noise)
# NEXT_PUBLIC_JUPYTER_VERBOSE=1
