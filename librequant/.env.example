# Public (exposed to browser) — use only for local dev
# Use 127.0.0.1 so the browser hits IPv4 loopback: Docker maps 127.0.0.1:8888 only; "localhost"
# often resolves to ::1 on macOS and fails with ECONNREFUSED. (App also normalizes localhost→127.0.0.1.)
NEXT_PUBLIC_JUPYTER_BASE_URL=http://127.0.0.1:8888
# Sensitive: equivalent to Jupyter login; do not commit real secrets to public repos
NEXT_PUBLIC_JUPYTER_TOKEN=devtoken

# Directory (Jupyter contents path) for the notebook library — relative to server root, no leading slash
NEXT_PUBLIC_JUPYTER_NOTEBOOK_ROOT=work/librequant

# When 1, strategies are on kernel PYTHONPATH (see docker-compose PYTHONPATH); skip browser sys.path injection.
# If you change NOTEBOOK_ROOT or USER_HOME, update PYTHONPATH in docker-compose.yml to match lib/env.ts.
NEXT_PUBLIC_STRATEGIES_VIA_PYTHONPATH=1

# Absolute path to Jupyter Linux user home inside the container (default /home/jovyan). Must be a safe POSIX path.
# NEXT_PUBLIC_JUPYTER_USER_HOME=/home/jovyan

# Docker Compose (must match NEXT_PUBLIC_JUPYTER_TOKEN when using compose defaults)
JUPYTER_TOKEN=devtoken

# Set to 1 to show full Jupyter/Yjs console output in dev (default filters known benign noise)
# NEXT_PUBLIC_JUPYTER_VERBOSE=1
